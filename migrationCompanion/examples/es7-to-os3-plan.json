{
  "version": "1.0.0",
  "name": "iter1-es7-to-os2",
  "source": {
    "engine": "elasticsearch",
    "version": "7.10.2",
    "endpoint": "https://elasticsearch-master:9200",
    "allowInsecure": true,
    "auth": {"mode": "basic", "secretName": "source-creds"}
  },
  "target": {
    "engine": "opensearch",
    "version": "2.11.1",
    "endpoint": "https://opensearch-cluster-master-headless:9200",
    "allowInsecure": true,
    "auth": {"mode": "basic", "secretName": "target-creds"}
  },
  "scope": {
    "indexPatterns": ["products", "events-2025.05", "legacy_orders"],
    "excludePatterns": [".*", "security-auditlog-*", "searchguard", "sg7-auditlog-*"],
    "rfsWorkers": 1
  },
  "mode": "full-backfill",
  "gates": {"autoApprove": true},
  "empirical": {
    "enabled": true,
    "kubeconfig": "/tmp/kind-iter0-logs/kubeconfig2",
    "namespace": "ma",
    "sampleSize": 0
  }
}
